{
  "buildCommand": "npm run vercel-build",
  "routes": [
    {
      "src": "/(.*)",
      "methods": ["OPTIONS"],
      "headers": {
        "Access-Control-Allow-Origin": "https://policy-management-frontend-coral.vercel.app",
        "Access-Control-Allow-Credentials": "true",
        "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS, PATCH",
        "Access-Control-Allow-Headers": "Content-Type, Authorization, role"
      },
      "continue": false,
      "status": 200
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}